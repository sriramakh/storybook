# ──────────────────────────────────────────────────────
# StoryBook Generator — Environment Variables
# ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env

# ── Required ──────────────────────────────────────────

# OpenAI — story generation (GPT-4o-mini) + image review + gpt-image provider
OPENAI_API_KEY=

# Google Gemini — fallback image generation + gemini provider
GEMINI_API_KEY=

# ── Telegram Bot (required for bot.py) ────────────────

TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=

# ── Optional: Image Provider ─────────────────────────

# Which image provider to use: gpt-image (default), gemini, minimax, cogview
IMAGE_PROVIDER=gpt-image

# ── Optional: MiniMax (only if IMAGE_PROVIDER=minimax) ─
MINIMAX_API_TOKEN=
MINIMAX_BASE_URL=https://api.minimax.io/v1

# ── Optional: CogView / ZhipuAI (only if IMAGE_PROVIDER=cogview) ─
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ── Optional: Model Overrides ────────────────────────

STORY_MODEL=gpt-4o-mini
IMAGE_MODEL=cogView-4-250304
IMAGE_SIZE=1024x1536

# ── Optional: Story Settings ─────────────────────────

MIN_SCENES=10
MAX_SCENES=15
OUTPUT_DIR=stories
